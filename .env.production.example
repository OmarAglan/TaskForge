# Database
POSTGRES_DB=taskforge
POSTGRES_USER=taskforge
POSTGRES_PASSWORD=replace-with-strong-password

# Backend security
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend CORS
CORS_ORIGIN=https://your-frontend-domain.com

# Frontend build-time configuration
VITE_API_URL=https://your-backend-domain.com/api/v1
VITE_WS_URL=https://your-backend-domain.com
VITE_APP_NAME=TaskForge
VITE_APP_VERSION=1.0.0

# Rate limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
